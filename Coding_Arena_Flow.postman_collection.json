          "raw": "{\n    \"contestId\": 1,\n    \"languageId\": 71,\n    \"sourceCode\": \"import sys\\ndata = sys.stdin.read().split()\\ncounts = {}\\nfor w in data[1:]:\\n    key = ''.join(sorted(w))\\n    counts[key] = counts.get(key, 0) + 1\\nprint(max(counts.values()) if counts else 1)\"\n}"
